# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# react-native-health v1.x は New Architecture 非対応。
# Podfile でグローバルに既定値を書き換えると Info.plist 側の設定と不整合になり得るため、
# ここでは既定値を強制せず、必要な設定はビルド構成側で明示する。
if ENV['RCT_NEW_ARCH_ENABLED'] == '1'
  raise "RNAppleHealthKit (react-native-health v1.x) does not support React Native New Architecture. Set RCT_NEW_ARCH_ENABLED=0 in your build configuration or upgrade the library."
end

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'megale_varka' do
  config = use_native_modules!
  pod 'RNAppleHealthKit', :path => '../node_modules/react-native-health', :inhibit_warnings => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
    # RCT_REMOVE_LEGACY_ARCH=1 is injected by react_native_post_install via GCC_PREPROCESSOR_DEFINITIONS
    # in the pods xcconfig, which disables RCT_EXPORT_METHOD and breaks react-native-health v1.x.
    # Override it to 0 by appending to the pod's xcconfig (last definition wins in clang).
    installer.pods_project.targets.each do |target|
      next unless target.name == 'RNAppleHealthKit'
      target.build_configurations.each do |cfg|
        xcconfig_path = cfg.base_configuration_reference&.real_path
        next unless xcconfig_path
        content = File.read(xcconfig_path.to_s)
        unless content.include?('RCT_REMOVE_LEGACY_ARCH=0')
          File.write(xcconfig_path.to_s,
            content + "\nGCC_PREPROCESSOR_DEFINITIONS = $(inherited) RCT_REMOVE_LEGACY_ARCH=0\n")
        end
      end
    end
  end
end
